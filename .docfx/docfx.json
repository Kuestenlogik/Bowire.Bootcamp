{
    "build": {
        "content": [
            {
                "files": [
                    "units/**/README.md",
                    "units/**/INSTRUCTIONS.md",
                    "units/**/toc.yml",
                    "capstone/**/README.md",
                    "capstone/**/REQUIREMENTS.md",
                    "capstone/**/ARCHITECTURE.md",
                    "capstone/**/toc.yml",
                    "README.md",
                    "LEARNING_PATHS.md",
                    "units-overview.md",
                    "ROADMAP.md",
                    "toc.yml",
                    "index.md"
                ],
                "exclude": [
                    "units/unit-1-samples/**"
                ],
                "src": ".."
            }
        ],
        "resource": [
            { "files": ["images/**"], "src": "." }
        ],
        "dest": "../artifacts/docs-learn",
        "template": ["default", "modern", "templates/bowire"],
        "globalMetadata": {
            "_appTitle": "Bowire Bootcamp",
            "_appName": "Bowire Bootcamp",
            "_appFaviconPath": "favicon.svg",
            "_enableSearch": true,
            "_enableNewTab": true,
            "_disableContribution": true,
            "_gitContribute": {
                "repo": "https://github.com/Kuestenlogik/Bowire.Bootcamp",
                "branch": "main"
            },
            "_gitUrlPattern": "github"
        },
        "postProcessors": ["ExtractSearchIndex"]
    }
}
