    <script>
      window.addEventListener('load', function () {
        var pre = document.getElementById('bowire-loading');
        if (!pre) return;
        pre.classList.add('is-hidden');
        setTimeout(function () { pre.remove(); }, 300);
      });

      // Mirror site/assets/js/main.js: toggle the header's `.scrolled`
      // class after 20px of scroll so it fades from transparent to a
      // translucent solid bar. Waits for DOMContentLoaded because this
      // script block is inlined in <head>, before the <header> element.
      document.addEventListener('DOMContentLoaded', function () {
        var h = document.getElementById('bowire-docs-header');
        if (!h) return;
        // Apply once immediately for cold loads that happen already past
        // the 20px threshold (e.g. the user hit a deep-link anchor).
        function sync() { h.classList.toggle('scrolled', window.scrollY > 20); }
        sync();
        window.addEventListener('scroll', sync, { passive: true });
      });

      // Alternating section backgrounds — mirrors the marketing site
      // (site/assets/css/style.css .features-group-alt pattern) so the
      // docs article breaks visually into the same rhythm as the site.
      // Wrap every H2 + the content until the next H2 into a <section>
      // and alternate a background class on them via box-shadow+clip-path.
      document.addEventListener('DOMContentLoaded', function () {
        var article = document.querySelector('article[data-uid]');
        if (!article) return;
        var kids = Array.from(article.children);
        var groups = [];
        var current = null;
        kids.forEach(function (node) {
          if (node.tagName === 'H2') {
            current = document.createElement('section');
            current.className = 'docs-article-group';
            groups.push(current);
          }
          if (current) current.appendChild(node);
          // If there's content before the first H2 (e.g. intro para
          // right after the H1), leave it in place — only wrap from
          // the first H2 onwards.
        });
        groups.forEach(function (g, i) {
          if (i % 2 === 1) g.classList.add('docs-article-group-alt');
          article.appendChild(g);
        });
      });
    </script>

