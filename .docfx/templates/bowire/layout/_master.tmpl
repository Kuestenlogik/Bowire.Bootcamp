        {{^_disableAffix}}
        <button type="button" class="docs-rail-tool bowire-outline-trigger" aria-controls="bowire-outline-overlay" aria-expanded="false" aria-label="On this page" title="On this page (Esc closes)" hidden>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        {{/_disableAffix}}
        {{^_disableToc}}
        <button type="button" class="docs-rail-tool bowire-sections-trigger" aria-controls="bowire-sections-overlay" aria-expanded="false" aria-label="Sections" title="Sections (Esc closes)" hidden>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </button>
        {{/_disableToc}}
      </div>
    </aside>
    {{/_disableAffix}}

    {{!--- MAIN CONTENT — same Bootstrap container-xxl shell modern uses
          so all the API page partials' grid classes still line up.
          With the subbar pattern, main only contains the article and
          related secondary chrome (contribution, next-article). The
          previous left .toc-offcanvas + right .affix slots are gone —
          their navs moved to the subpanels above. -----------------}}
    <main class="container-xxl bowire-docs-main-shell">
      <div class="content">
        {{^_disableBreadcrumb}}
        <div class="actionbar">
          <nav id="breadcrumb"></nav>
        </div>
        {{/_disableBreadcrumb}}

        <article data-uid="{{uid}}">
          {{!body}}
        </article>

        {{^_disableContribution}}
        <div class="contribution d-print-none">
          {{#sourceurl}}
          <a href="{{sourceurl}}" class="edit-link">{{__global.improveThisDoc}}</a>
          {{/sourceurl}}
          {{^sourceurl}}{{#docurl}}
          <a href="{{docurl}}" class="edit-link">{{__global.improveThisDoc}}</a>
          {{/docurl}}{{/sourceurl}}
        </div>
        {{/_disableContribution}}

        {{^_disableNextArticle}}
        <div class="next-article d-print-none border-top" id="nextArticle"></div>
        {{/_disableNextArticle}}
      </div>
    </main>

    {{#_enableSearch}}
    <div class="container-xxl search-results" id="search-results"></div>
    {{/_enableSearch}}

    {{!--- Theme toggle wiring — mirrors site/assets/js/main.js's theme
          toggle so the cycle / icon / localStorage behaviour is identical
          across site and docs. Syncs both data-bs-theme (Bootstrap /
          docfx) and data-theme (Jekyll site convention). --------}}
    <script>
      (function () {
        var btn = document.getElementById('bowire-docs-theme-toggle');
        if (!btn) return;
        var icons = {
          light: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>',
          dark: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>',
          auto: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 3 a 9 9 0 0 1 0 18 z" fill="currentColor" stroke="none"/></svg>'
        };
        function resolved(mode) {
          if (mode === 'auto') return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          return mode;
        }
        function apply(mode) {
          document.documentElement.setAttribute('data-bs-theme', resolved(mode));
          document.documentElement.setAttribute('data-theme', mode);
          localStorage.setItem('theme', mode);
          btn.innerHTML = icons[mode] || icons.auto;
          btn.setAttribute('title', 'Theme: ' + mode);
        }
        var cycle = ['light', 'dark', 'auto'];
        apply(localStorage.getItem('theme') || 'auto');
        btn.addEventListener('click', function (ev) {
          var cur = localStorage.getItem('theme') || 'auto';
          var next = cycle[(cycle.indexOf(cur) + 1) % cycle.length];
          var commit = function () { apply(next); };
          // Same circular-reveal pattern as the marketing site — the
          // CSS rules in main.css animate ::view-transition-new(root)
          // as an expanding clip-path circle from the button centre.
          // Browsers without the View Transitions API (Firefox as of
          // mid-2026) fall through to the instant swap below.
          if (!document.startViewTransition) {
            commit();
            return;
          }
          var rect = btn.getBoundingClientRect();
          var x = rect.left + rect.width / 2;
          var y = rect.top + rect.height / 2;
          document.documentElement.style.setProperty('--theme-transition-x', x + 'px');
          document.documentElement.style.setProperty('--theme-transition-y', y + 'px');
          document.startViewTransition(commit);
        });
      })();
    </script>

    {{!--- Custom breadcrumb populator — DocFX's upstream
          renderBreadcrumb() depends on <nav id="navbar"> being
          rendered (we don't), so its runtime always emits an empty
          breadcrumb list. We build our own by fetching the parent
          toc.json (via the docfx:tocrel meta), walking it to find
          the current page's path, and rendering the trail directly
          into <nav id="breadcrumb">. ----------------------------}}
    <script>
      (function () {
        var nav = document.getElementById('breadcrumb');
        if (!nav) return;

        function rel(meta) {
          var el = document.querySelector('meta[name="' + meta + '"]');
          return el ? el.getAttribute('content') : null;
        }

        // Walk the toc tree depth-first; return the chain of
        // ancestors leading to the page that matches `currentHref`.
        // All topicHrefs are resolved to absolute URLs against the
        // toc's base — that way the rendered <a href> never depends
        // on which page the breadcrumb is sitting on.
        function findChain(items, currentHref, baseHref) {
          if (!items) return null;
          for (var i = 0; i < items.length; i++) {
            var it = items[i];
            var topic = it.topicHref || it.href;
            var absUrl = topic ? new URL(topic, baseHref).href : null;
            var entry = { name: it.name, url: absUrl };
            if (absUrl === currentHref) return [entry];
            if (it.items) {
              var sub = findChain(it.items, currentHref, baseHref);
              if (sub) return [entry].concat(sub);
            }
          }
          return null;
        }

        function render(crumbs) {
          if (!crumbs || crumbs.length === 0) return;
          var ol = document.createElement('ol');
          ol.className = 'breadcrumb';
          // "Bootcamp" root link as the first crumb so even
          // top-level section pages get a back-to-home anchor.
          var rootHref = new URL('{{_rel}}index.html', location.href).href;
          var rootLi = document.createElement('li');
          rootLi.className = 'breadcrumb-item';
          rootLi.innerHTML = '<a href="' + rootHref + '">Bootcamp</a>';
          ol.appendChild(rootLi);
          crumbs.forEach(function (c, i) {
            var li = document.createElement('li');
            var isLast = i === crumbs.length - 1;
            li.className = 'breadcrumb-item' + (isLast ? ' active' : '');
            if (isLast) {
              li.setAttribute('aria-current', 'page');
              li.textContent = c.name;
            } else if (c.url) {
              var a = document.createElement('a');
              a.href = c.url;
              a.textContent = c.name;
              li.appendChild(a);
            } else {
              li.textContent = c.name;
            }
            ol.appendChild(li);
          });
          nav.innerHTML = '';
          nav.appendChild(ol);
        }

        async function build() {
          // Walk parent TOCs from the closest one upward — for a deep
          // page like /docs/protocols/udp.html the closest toc.html is
          // /docs/protocols/toc.json (lists UDP), and the parent is
          // /docs/toc.json (lists "Protocol Guides"). Combining both
          // gives the full Documentation > Protocol Guides > UDP chain.
          var tocrel = rel('docfx:tocrel');
          if (!tocrel) return;
          var tocUrl = new URL(tocrel.replace(/\.html$/, '.json'), location.href).href;
          var resp = await fetch(tocUrl);
          if (!resp.ok) return;
          var toc = await resp.json();
          var chain = findChain(toc.items, location.href, tocUrl);
          // If the page is the index of its tocrel folder, the chain
          // is just one item — walk up to the parent toc to also
          // include the section name as the parent crumb.
          var navrel = rel('docfx:navrel');
          if (navrel && navrel !== tocrel) {
            var navUrl = new URL(navrel.replace(/\.html$/, '.json'), location.href).href;
            try {
              var navResp = await fetch(navUrl);
              if (navResp.ok) {
                var navToc = await navResp.json();
                var sectionHref = new URL(tocrel, location.href).href.replace(/\.html$/, '.json').replace(/[^\/]+$/, '');
                // Find the parent section that points at this folder
                // and prepend its name to the chain. Resolve topicHref
                // to an absolute URL so the rendered link doesn't
                // double up the path on pages deep inside the section.
                (function walk(items) {
                  if (!items) return;
                  for (var i = 0; i < items.length; i++) {
                    var it = items[i];
                    if (it.tocHref) {
                      var t = new URL(it.tocHref.replace(/\.html$/, '.json'), navUrl).href;
                      if (t.replace(/[^\/]+$/, '') === sectionHref) {
                        var absUrl = it.topicHref
                          ? new URL(it.topicHref, navUrl).href
                          : null;
                        // Dedup: if the section's own page IS the
                        // current page (e.g. /docs/protocols/index.html),
                        // the chain already has a single entry with the
                        // same URL. Replace it with the parent toc's
                        // section name ("Protocol Guides") rather than
                        // the page-level name ("Overview") and skip
                        // prepending — otherwise the breadcrumb shows
                        // "Protocol Guides › Overview" with both entries
                        // linking to the same page.
                        if (chain && chain.length === 1 && chain[0].url === absUrl) {
                          chain[0].name = it.name;
                        } else {
                          chain = [{ name: it.name, url: absUrl }].concat(chain || []);
                        }
                        return;
                      }
                    }
                    if (it.items) walk(it.items);
                  }
                })(navToc.items);
              }
            } catch (e) { /* fall through with current-toc-only chain */ }
          }
          render(chain);
          emitJsonLd();
        }

        // schema.org BreadcrumbList JSON-LD — emitted into <head> after
        // the breadcrumb is filled. Picked up by Google Search (which
        // runs JS on indexed pages) for the rich-result breadcrumb trail.
        function emitJsonLd() {
          var links = nav.querySelectorAll('.breadcrumb-item');
          if (links.length < 2) return;
          var items = [];
          links.forEach(function (li, i) {
            var a = li.querySelector('a');
            items.push({
              '@type': 'ListItem',
              position: i + 1,
              name: (a || li).textContent.trim(),
              item: a ? a.href : location.href
            });
          });
          var ld = {
            '@context': 'https://schema.org',
            '@type': 'BreadcrumbList',
            itemListElement: items
          };
          var prev = document.head.querySelector('script[data-bowire-breadcrumb]');
          if (prev) prev.remove();
          var s = document.createElement('script');
          s.type = 'application/ld+json';
          s.setAttribute('data-bowire-breadcrumb', '');
          s.textContent = JSON.stringify(ld);
          document.head.appendChild(s);
        }

        build();
      })();
    </script>

    {{!--- Modal overlays for the docs page — Sections (site TOC) +
          Outline (article headings). Both share one factory:
            • Click on the trigger toggles open/close
            • ArrowUp/Down moves the .is-highlighted cursor
            • Enter opens the highlighted item
            • Mouse hover syncs the cursor (keyboard + pointer state
              share one variable so input modality switches don't
              lose context — same idiom as the search overlay)
            • Click on a link navigates and auto-closes
            • Backdrop click / Esc closes
          When one overlay opens, all others close so the user is
          never juggling stacked modals. ----------------------}}
    <script>
      (function () {
        function makeOverlay(opts) {
          var overlay = document.querySelector(opts.overlay);
          var trigger = document.querySelector(opts.trigger);
          if (!overlay || !trigger) return null;
          var highlighted = -1;
          var api = { overlay: overlay, trigger: trigger, close: closeFn };
          function items() {
            return Array.from(overlay.querySelectorAll(opts.linkSelector));
          }
          function paint() {
            var list = items();
            list.forEach(function (el, i) {
              el.classList.toggle('is-highlighted', i === highlighted);
            });
            if (highlighted >= 0 && list[highlighted]) {
              list[highlighted].scrollIntoView({ block: 'nearest' });
            }
          }
          function isOpen() { return overlay.classList.contains('is-open'); }
          function openFn() {
            // Close any sibling overlays first — single-modal-at-a-time UX.
            window.__bowireDocsOverlays__.forEach(function (o) {
              if (o !== api) o.close();
            });
            overlay.classList.add('is-open');
            overlay.setAttribute('aria-hidden', 'false');
            trigger.setAttribute('aria-expanded', 'true');
            highlighted = -1;
            paint();
          }
          function closeFn() {
            overlay.classList.remove('is-open');
            overlay.setAttribute('aria-hidden', 'true');
            trigger.setAttribute('aria-expanded', 'false');
            highlighted = -1;
          }
          trigger.addEventListener('click', function (e) {
            e.preventDefault();
            isOpen() ? closeFn() : openFn();
          });
          overlay.addEventListener('click', function (e) {
            if (e.target.closest(opts.panel + ' a')) {
              setTimeout(closeFn, 0);
              return;
            }
            if (e.target === overlay) closeFn();
          });
          overlay.addEventListener('mouseover', function (e) {
            var link = e.target.closest(opts.linkSelector);
            if (!link) return;
            var list = items();
            var idx = list.indexOf(link);
            if (idx === -1 || idx === highlighted) return;
            highlighted = idx;
            paint();
          });
          document.addEventListener('keydown', function (e) {
            if (!isOpen()) return;
            if (e.key === 'Escape') { closeFn(); return; }
            var list = items();
            if (list.length === 0) return;
            if (e.key === 'ArrowDown') {
              e.preventDefault();
              highlighted = (highlighted + 1) % list.length;
              paint();
            } else if (e.key === 'ArrowUp') {
              e.preventDefault();
              highlighted = highlighted < 0
                ? list.length - 1
                : (highlighted - 1 + list.length) % list.length;
              paint();
            } else if (e.key === 'Enter') {
              if (highlighted >= 0 && list[highlighted]) {
                e.preventDefault();
                list[highlighted].click();
              }
            }
          });
          return api;
        }

        window.__bowireDocsOverlays__ = [];
        ['sections', 'outline'].forEach(function (name) {
          var overlayId = 'bowire-' + name + '-overlay';
          var triggerCls = 'bowire-' + name + '-trigger';
          var linkSel = name === 'sections'
            ? '#' + overlayId + ' nav#toc a'
            : '#' + overlayId + ' nav#affix a';
          var api = makeOverlay({
            overlay: '#' + overlayId,
            trigger: '.' + triggerCls,
            panel: '.bowire-docs-overlay-panel',
            linkSelector: linkSel
          });
          if (api) window.__bowireDocsOverlays__.push(api);
        });
      })();
    </script>

    {{!--- Rail visibility manager — each tool button + the dot pill +
          the rail itself only show when their content has something
          to offer. Runs at DOMContentLoaded and re-runs whenever the
          underlying nav#toc / nav#affix mutates (DocFX populates them
          asynchronously after page load). ---------------------}}
    <script>
      (function () {
        function refreshRailVisibility() {
          var rail = document.querySelector('.docs-rail');
          if (!rail) return;
          var sectionsBtn = document.querySelector('.bowire-sections-trigger');
          var outlineBtn = document.querySelector('.bowire-outline-trigger');
          var dotNav = document.querySelector('.docs-section-nav');
          var toolsPill = rail.querySelector('.docs-rail-tools');
          var hasToc = document.querySelectorAll('#bowire-sections-overlay nav#toc a').length > 0;
          var hasAffix = document.querySelectorAll('#bowire-outline-overlay nav#affix a').length > 0;
          if (sectionsBtn) sectionsBtn.toggleAttribute('hidden', !hasToc);
          if (outlineBtn) outlineBtn.toggleAttribute('hidden', !hasAffix);
          var anyTool = hasToc || hasAffix;
          if (toolsPill) toolsPill.toggleAttribute('hidden', !anyTool);
          var dotVisible = dotNav && !dotNav.hasAttribute('hidden');
          rail.toggleAttribute('hidden', !anyTool && !dotVisible);
        }

        document.addEventListener('DOMContentLoaded', function () {
          refreshRailVisibility();
          // DocFX populates nav#toc / nav#affix asynchronously after
          // DOMContentLoaded — observe each so the rail toggles in as
          // the content lands.
          ['#toc', '#affix'].forEach(function (sel) {
            var nav = document.querySelector(sel);
            if (!nav) return;
            new MutationObserver(refreshRailVisibility).observe(nav, { childList: true, subtree: true });
          });
        });
      })();
    </script>

    {{!--- Floating section-nav — scrollspy dots pinned to the right
          edge of the viewport, mirroring site/assets/js/main.js's
          marketing-site .section-nav pattern. Built from the article's
          h2 elements at DOMContentLoaded; updates the active dot as
          the user scrolls. Carries an expand toggle at the top of the
          pill that flips the whole strip into a wider labelled-list
          mode (every section's title visible inline, no need to hover
          individual dots). State persists in localStorage. Hidden on
          mobile via CSS (< 768 px). -----------------------------}}
    <script>
      (function () {
        document.addEventListener('DOMContentLoaded', function () {
          var nav = document.querySelector('nav.docs-section-nav');
          if (!nav) return;
          var article = document.querySelector('main article[data-uid], main article');
          if (!article) return;
          // Conceptual pages use H2 for major sections; API ref pages
          // (where the page title is the namespace / type) drop H2 and
          // use H3 instead for "Classes", "Methods", etc. Try H2 first;
          // fall back to H3 if too few H2 are present.
          var headings = Array.from(article.querySelectorAll('h2'))
              .filter(function (h) { return h.id && h.textContent.trim(); });
          if (headings.length < 2) {
            headings = Array.from(article.querySelectorAll('h3'))
                .filter(function (h) { return h.id && h.textContent.trim(); });
          }
          if (headings.length < 2) {
            // No anchors worth navigating — hide the whole right rail
            // (tools pill + dot-nav pill). The outline overlay would
            // also be near-empty on these pages, so the rail's only
            // affordance is moot.
            var rail = document.querySelector('.docs-rail');
            if (rail) rail.setAttribute('hidden', '');
            return;
          }

          headings.forEach(function (h, idx) {
            if (!h.id) {
              h.id = 'section-' + idx + '-' + h.textContent.trim().toLowerCase()
                .replace(/[^a-z0-9\-]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 40);
            }
          });

          // Sample down to MAX_DOTS evenly across the article when there
          // are more headings than the pill can show without becoming a
          // visual wall. Always anchored at first + last so the strip
          // still represents the full document range; gaps between non-
          // adjacent picks are flagged with a small inline marker so the
          // user can tell the strip is sampled (and use the Sections /
          // Outline overlays to find anything skipped).
          var MAX_DOTS = 8;
          var pickedIndexes;
          if (headings.length <= MAX_DOTS) {
            pickedIndexes = headings.map(function (_, i) { return i; });
          } else {
            var seen = {};
            pickedIndexes = [];
            for (var i = 0; i < MAX_DOTS; i++) {
              var idx = Math.round(i * (headings.length - 1) / (MAX_DOTS - 1));
              if (!seen[idx]) {
                seen[idx] = true;
                pickedIndexes.push(idx);
              }
            }
          }

          var dots = [];
          pickedIndexes.forEach(function (headingIdx, i) {
            var h = headings[headingIdx];
            var label = h.textContent.trim() || ('Section ' + (headingIdx + 1));
            var btn = document.createElement('a');
            btn.href = '#' + h.id;
            btn.className = 'docs-section-nav-dot';
            btn.setAttribute('aria-label', 'Jump to ' + label);
            btn.innerHTML = '<span class="docs-section-nav-dot-label"></span>';
            btn.querySelector('.docs-section-nav-dot-label').textContent = label;
            nav.appendChild(btn);
            dots.push({ heading: h, btn: btn });

            if (i < pickedIndexes.length - 1
                && pickedIndexes[i + 1] > headingIdx + 1) {
              var gap = document.createElement('span');
              gap.className = 'docs-section-nav-gap';
              gap.setAttribute('aria-hidden', 'true');
              nav.appendChild(gap);
            }
          });
          nav.removeAttribute('hidden');

          function activeIndex() {
            var threshold = window.scrollY + 80 + 40;
            var headingActive = 0;
            for (var i = 0; i < headings.length; i++) {
              var top = headings[i].getBoundingClientRect().top + window.scrollY;
              if (top <= threshold) headingActive = i;
              else break;
            }
            var dotIdx = 0;
            for (var j = 0; j < pickedIndexes.length; j++) {
              if (pickedIndexes[j] <= headingActive) dotIdx = j;
              else break;
            }
            var bottomReached = (window.innerHeight + window.scrollY)
              >= (document.documentElement.scrollHeight - 4);
            if (bottomReached) dotIdx = dots.length - 1;
            return dotIdx;
          }

          function syncActive() {
            var idx = activeIndex();
            dots.forEach(function (d, i) {
              d.btn.classList.toggle('is-active', i === idx);
            });
          }
          syncActive();
          window.addEventListener('scroll', syncActive, { passive: true });
          window.addEventListener('resize', syncActive, { passive: true });
        });
      })();
    </script>

    {{!--- Fenced-code-block copy buttons — wraps every `<pre><code>`
          inside the article with a hover-revealed copy button that
          mirrors the marketing site's .copy-btn pattern. Idempotent:
          re-running over an already-wrapped block is a no-op so DocFX
          hot-reload doesn't double-wrap. Bails on `<pre>` that already
          has a parent .docs-code-block (e.g. server-side template
          rewrites in the future). -----------------------------------}}
    <script>
      (function () {
        function svg(path) {
          return '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' + path + '</svg>';
        }
        var COPY_ICON = svg('<rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>');
        var CHECK_ICON = svg('<polyline points="20 6 9 17 4 12"/>');

        function wrapPre(pre) {
          if (!pre || pre.parentElement && pre.parentElement.classList.contains('docs-code-block')) return;
          var code = pre.querySelector('code');
          if (!code) return;
          var snippet = code.textContent.replace(/\s+$/, '');
          if (!snippet) return;

          var wrapper = document.createElement('div');
          wrapper.className = 'docs-code-block';
          pre.parentNode.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);

          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'docs-code-copy';
          btn.setAttribute('aria-label', 'Copy code');
          btn.setAttribute('title', 'Copy');
          btn.innerHTML = COPY_ICON;
          wrapper.appendChild(btn);

          btn.addEventListener('click', function (e) {
            e.preventDefault();
            if (!navigator.clipboard) return;
            navigator.clipboard.writeText(snippet).then(function () {
              btn.classList.add('is-copied');
              btn.innerHTML = CHECK_ICON;
              setTimeout(function () {
                btn.classList.remove('is-copied');
                btn.innerHTML = COPY_ICON;
              }, 1500);
            }).catch(function () { /* swallow — clipboard refused */ });
          });
        }

        function wrapAll() {
          var article = document.querySelector('main article');
          if (!article) return;
          var preEls = article.querySelectorAll('pre');
          for (var i = 0; i < preEls.length; i++) wrapPre(preEls[i]);
        }

        document.addEventListener('DOMContentLoaded', wrapAll);
        // DocFX populates some content asynchronously (xref resolution
        // can inject code blocks after DOMContentLoaded). Run a single
        // late pass via window.load so any post-DCL `<pre>` blocks get
        // wrapped too.
        window.addEventListener('load', wrapAll);
      })();
    </script>

