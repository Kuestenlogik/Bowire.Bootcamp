    {{!--- Pagefind search overlay — shared with the marketing site's
          _layouts/default.html. Same widget, same index, same UX across
          marketing site and docs. ---------------------------------}}
    <div class="bowire-search-overlay" id="bowire-search-overlay" aria-hidden="true">
      <div class="bowire-search-overlay-panel" role="dialog" aria-label="Search">
        <div id="search"></div>
        <div class="bowire-search-hint">
          <kbd>↑</kbd><kbd>↓</kbd> navigate · <kbd>Enter</kbd> open selected / full results · <kbd>Esc</kbd> close
        </div>
      </div>
    </div>
    <script src="{{_rel}}../pagefind/pagefind-ui.js"
            onerror="(function(){var b=document.querySelector('.bowire-search-trigger');if(b){b.disabled=true;b.title='Search index not available — run scripts/build-docs.{ps1,sh} or `npx pagefind --site artifacts/docs --output-path artifacts/docs/pagefind`';b.setAttribute('aria-disabled','true');}})()"></script>
    <script>
      (function () {
        function initSearch() {
          if (!window.PagefindUI) {
            // pagefind-ui.js never loaded (404 or hosting hadn't run
            // pagefind yet). The script tag's onerror already greyed
            // out the trigger; this just bails before initialising
            // PagefindUI / wiring the open/close listeners.
            var b = document.querySelector('.bowire-search-trigger');
            if (b && !b.disabled) {
              b.disabled = true;
              b.title = 'Search index not available — run pagefind on artifacts/docs first';
              b.setAttribute('aria-disabled', 'true');
            }
            return;
          }
          var link = document.querySelector('link[href*="/pagefind/pagefind-ui.css"]');
          var bundlePath = link
            ? link.getAttribute('href').replace(/pagefind-ui\.css$/, '')
            : '../pagefind/';
          new window.PagefindUI({
            element: '#search',
            showImages: false,
            showSubResults: false,
            resetStyles: false,
            pageSize: 5,
            bundlePath: bundlePath
          });

          var overlay = document.getElementById('bowire-search-overlay');
          var highlighted = -1;
          function getResults() {
            return Array.from(document.querySelectorAll('#search .pagefind-ui__result'));
          }
          function paintHighlight() {
            var items = getResults();
            items.forEach(function (el, i) {
              el.classList.toggle('is-highlighted', i === highlighted);
            });
            if (highlighted >= 0 && items[highlighted]) {
              items[highlighted].scrollIntoView({ block: 'nearest' });
            }
          }
          // MutationObserver covers two responsibilities each time
          // PagefindUI re-renders its tree:
          //   1. Reset the keyboard-highlight cursor.
          //   2. Promote the result-count message out of .pagefind-ui__
          //      drawer so it sits in the form's header zone (between
          //      the input and the results scroll area). PagefindUI puts
          //      it inside the drawer by default; visually we want it
          //      on the tertiary header bg, not on the secondary
          //      results bg.
          new MutationObserver(function () {
            highlighted = -1;
            paintHighlight();
            var msg = document.querySelector('#search .pagefind-ui__message');
            var drawer = document.querySelector('#search .pagefind-ui__drawer');
            var form = document.querySelector('#search .pagefind-ui__form');
            if (msg && drawer && form && drawer.contains(msg)) {
              form.insertBefore(msg, drawer);
            }
          }).observe(document.getElementById('search'), { childList: true, subtree: true });

          // Infinite-scroll: when the user scrolls within ~80 px of the
          // drawer's bottom edge, auto-click PagefindUI's "Load more
          // results" button (we keep it hidden via CSS for visual
          // simplicity; this listener turns the page into infinite
          // scroll so the keyboard ArrowDown path isn't the only way
          // to expose the rest of the index).
          var drawerEl = document.querySelector('#search .pagefind-ui__drawer');
          if (drawerEl) {
            var loading = false;
            drawerEl.addEventListener('scroll', function () {
              if (loading) return;
              if (drawerEl.scrollTop + drawerEl.clientHeight < drawerEl.scrollHeight - 80) return;
              var loadMore = document.querySelector('#search .pagefind-ui__button');
              if (!loadMore) return;
              loading = true;
              loadMore.click();
              setTimeout(function () { loading = false; }, 200);
            }, { passive: true });

            // Mouse hover mirrors keyboard ArrowUp/Down — moving the
            // pointer over a result moves the .is-highlighted marker
            // there, so the visual cursor follows whichever input
            // device the user used last.
            drawerEl.addEventListener('mouseover', function (e) {
              var result = e.target.closest('.pagefind-ui__result');
              if (!result) return;
              var items = getResults();
              var idx = items.indexOf(result);
              if (idx === -1 || idx === highlighted) return;
              highlighted = idx;
              paintHighlight();
            });
            // Single click anywhere on a result row navigates — the
            // entire card behaves like a link. If the click already
            // landed on the title's <a>, the browser handles it
            // natively and we no-op to avoid a double dispatch.
            drawerEl.addEventListener('click', function (e) {
              if (e.target.closest('a')) return;
              var result = e.target.closest('.pagefind-ui__result');
              if (!result) return;
              var link = result.querySelector('a');
              if (link) link.click();
            });
          }

          function open() {
            overlay.classList.add('is-open');
            overlay.setAttribute('aria-hidden', 'false');
            var input = document.querySelector('#search input[type="text"]');
            if (input) setTimeout(function () { input.focus(); }, 50);
          }
          function close() {
            overlay.classList.remove('is-open');
            overlay.setAttribute('aria-hidden', 'true');
            highlighted = -1;
          }
          document.addEventListener('click', function (e) {
            var trigger = e.target.closest('.bowire-search-trigger');
            if (trigger) { e.preventDefault(); open(); return; }
            if (e.target === overlay) close();
          });
          document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && overlay.classList.contains('is-open')) close();
            if ((e.key === '/' || (e.key === 'k' && (e.metaKey || e.ctrlKey))) &&
                !/^(INPUT|TEXTAREA)$/i.test(document.activeElement.tagName)) {
              e.preventDefault();
              open();
            }
            if (!overlay.classList.contains('is-open')) return;
            var active = document.activeElement;
            var isInput = active && active.matches && active.matches('.pagefind-ui__search-input');
            if (!isInput) return;
            if (e.key === 'ArrowDown') {
              e.preventDefault();
              var items = getResults();
              if (items.length === 0) return;
              if (highlighted === items.length - 1) {
                var loadMore = document.querySelector('#search .pagefind-ui__button');
                if (loadMore) {
                  loadMore.click();
                  var prevLen = items.length;
                  setTimeout(function () {
                    var next = getResults();
                    if (next.length > prevLen) {
                      highlighted = prevLen;
                      paintHighlight();
                    }
                  }, 150);
                }
                return;
              }
              highlighted = Math.min(highlighted + 1, items.length - 1);
              paintHighlight();
              return;
            }
            if (e.key === 'ArrowUp') {
              e.preventDefault();
              var items = getResults();
              if (items.length === 0) return;
              highlighted = Math.max(highlighted - 1, -1);
              paintHighlight();
              return;
            }
            if (e.key === 'Enter') {
              e.preventDefault();
              var items = getResults();
              if (highlighted >= 0 && items[highlighted]) {
                var link = items[highlighted].querySelector('a.pagefind-ui__result-link');
                if (link) { window.location = link.href; return; }
              }
              var q = (active.value || '').trim();
              if (!q) return;
              close();
              window.location = '{{_rel}}../search.html?q=' + encodeURIComponent(q);
            }
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initSearch);
        } else {
          initSearch();
        }
      })();
    </script>

  </body>
  {{/redirect_url}}
</html>
