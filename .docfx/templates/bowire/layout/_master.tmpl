      {{!--- Favicon — same Bowire indigo-tile + white-B mark used on
            the marketing site, app icon, and browser tab. ----------}}
      <link rel="icon" type="image/svg+xml" href="{{_rel}}public/favicon.svg">
      <link rel="alternate icon" type="image/x-icon" href="{{_rel}}{{{_appFaviconPath}}}{{^_appFaviconPath}}favicon.ico{{/_appFaviconPath}}">

      {{!--- Theme bootstrap — MUST run before any stylesheet link so the
            data-bs-theme attribute is set when the critical CSS below
            applies. Otherwise the browser blocks the first paint on the
            external stylesheets (google fonts, docfx.min.css, main.css)
            and the user sees a white flash before our bg/preloader
            style kicks in. -----------------------------------------}}
      <script>
        (function () {
          var mode = localStorage.getItem('theme') || 'auto';
          var resolved = mode === 'auto'
            ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
            : mode;
          var el = document.documentElement;
          el.setAttribute('data-bs-theme', resolved);
          el.setAttribute('data-theme', mode);
        })();
      </script>

      {{!--- Critical CSS — paints body bg + preloader synchronously
            before docfx.min.css + main.css arrive. Preloader is the
            Bowire app's pattern: 80px rotating indigo ring with the
            40px B-tile centred inside. Same keyframes, same palette. }}
      <style>
        :root[data-bs-theme="dark"] {
          background: #0f0f17;
          color: #e8e8f0;
        }
        :root[data-bs-theme="light"] {
          background: #fafaff;
          color: #1a1a2e;
        }
        html, body {
          margin: 0;
          background: inherit;
          color: inherit;
          font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }
        #bowire-loading {
          position: fixed;
          inset: 0;
          display: flex;
          align-items: center;
          justify-content: center;
          z-index: 9999;
          background: #0f0f17;
          transition: opacity 300ms ease;
        }
        :root[data-bs-theme="light"] #bowire-loading,
        :root[data-theme="light"] #bowire-loading {
          background: #fafaff;
        }
        .bowire-loading-wrap {
          position: relative;
          width: 80px;
          height: 80px;
          display: flex;
          align-items: center;
          justify-content: center;
          color: #e8e8f0;
        }
        :root[data-bs-theme="light"] .bowire-loading-wrap,
        :root[data-theme="light"] .bowire-loading-wrap {
          color: #1a1a2e;
        }
        .bowire-loading-logo-ring {
          position: absolute;
          inset: 0;
          border: 3px solid #2a2a3d;
          border-top-color: #6366f1;
          border-radius: 50%;
          animation: bowire-spin 800ms linear infinite;
        }
        :root[data-bs-theme="light"] .bowire-loading-logo-ring,
        :root[data-theme="light"] .bowire-loading-logo-ring {
          border-color: #d8dae5;
          border-top-color: #4f46e5;
        }
        .bowire-loading-logo {
          width: 40px;
          height: 40px;
          position: relative;
          z-index: 1;
          color: inherit;
        }
        @keyframes bowire-spin {
          to { transform: rotate(360deg); }
        }
        #bowire-loading.is-hidden {
          opacity: 0;
          pointer-events: none;
        }
      </style>

      {{!--- Inter + JetBrains Mono — loaded AFTER critical CSS so the
            render-blocking on font CSS doesn't delay our brand-coloured
            first paint. ------------------------------------------}}
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

